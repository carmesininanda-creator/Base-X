# ─── IA (obrigatório) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Segurança (obrigatório em produção) ──────────────────────────
# Token de operadora: gerencia membros; em modo família NÃO lê memória
GIU_API_TOKEN=

# ─── Modo Família (Giu Família) ───────────────────────────────────
# 1 = só membros registrados conversam (ver ARQUITETURA-FAMILIA.md)
GIU_FAMILY_MODE=0

# ─── WhatsApp Cloud API (opcional — ver README) ───────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=giu-bazex
# App Secret da Meta — valida a assinatura dos webhooks
META_APP_SECRET=

# ─── Telegram (opcional — token do @BotFather) ────────────────────
TELEGRAM_BOT_TOKEN=
# Secret para validar os webhooks (qualquer string aleatória)
TELEGRAM_SECRET_TOKEN=

# ─── Google Calendar (opcional — ver README) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ─── Voz (identidade sonora — configurável; padrão do piloto) ─────
# A voz DEFINITIVA será decidida por teste de percepção com usuários.
GIU_VOICE_ENABLED=1
GIU_VOICE=shimmer          # timbre do TTS (alloy, echo, fable, onyx, nova, shimmer)
GIU_VOICE_SPEED=0.92       # ~0,9x: calma, "tenho tempo pra você"
GIU_VOICE_REPLIES=1        # responder em áudio quando a pessoa manda áudio
# GIU_TTS_MODEL=tts-1
# GIU_STT_MODEL=whisper-1

# ─── Geral ────────────────────────────────────────────────────────
GIU_TIMEZONE=America/Sao_Paulo
# GIU_DB_PATH=/caminho/para/giu_memory.db

# ─── Check-in diário proativo (horário local) ─────────────────────
GIU_MORNING_CHECKIN=08:00
GIU_NIGHT_CHECKIN=21:00
