# ─── IA (obrigatório) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Segurança (obrigatório em produção) ──────────────────────────
# Token Bearer exigido em /chat, /memories e /pending-actions
GIU_API_TOKEN=

# ─── WhatsApp Cloud API (opcional — ver README) ───────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=giu-bazex
# App Secret da Meta — valida a assinatura dos webhooks
META_APP_SECRET=

# ─── Telegram (opcional — token do @BotFather) ────────────────────
TELEGRAM_BOT_TOKEN=
# Secret para validar os webhooks (qualquer string aleatória)
TELEGRAM_SECRET_TOKEN=

# ─── Google Calendar (opcional — ver README) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ─── Geral ────────────────────────────────────────────────────────
GIU_TIMEZONE=America/Sao_Paulo
# GIU_DB_PATH=/caminho/para/giu_memory.db
